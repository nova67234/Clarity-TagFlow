# Rust build output
/target

# Packaged build artifacts (regenerated locally / by CI — don't commit)
/dist
# Ignore the installer dir EXCEPT Info.plist, which the macOS release CI copies
# into the app bundle. (The old installer/ClarityTagFlow.iss is unused — the
# Windows installer is built from packaging/windows-installer.iss.)
/installer/*
!/installer/Info.plist
/Clarity_TagFlow.zip
*.dmg

# Downloaded AI models (1.7GB; fetched in-app via the AI Model Manager)
/tools

# Backups created by the app while testing
/images/backups

# Debug screenshots
/images/*.png

# Local test sample sets / media fixtures (not committed — kept on disk only)
/avif
/tests

# Original Python/Java sources kept locally as a porting reference (already ported)
/covert to rust

# Machine-specific local cargo config (e.g. the VLC lib path) — not portable.
/.cargo

# Editor / tooling local state
/.idea
/.claude
/.vscode

# Local Pixal3D / debug logs (not part of the project)
errors/
